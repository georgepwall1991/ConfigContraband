<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsRoslynComponent>true</IsRoslynComponent>
    <RootNamespace>ConfigContraband</RootNamespace>
    <AssemblyName>ConfigContraband</AssemblyName>
    <NoWarn>$(NoWarn);RS1038;RS1037</NoWarn>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>ConfigContraband</PackageId>
    <Version>0.3.0</Version>
    <Authors>George Wall</Authors>
    <Title>ConfigContraband</Title>
    <Description>Stop smuggling broken appsettings into production. ConfigContraband is a Roslyn analyzer for .NET Options and configuration correctness.</Description>
    <PackageTags>configuration;options;appsettings;dotnet;csharp;aspnetcore;roslyn;roslyn-analyzer;analyzers;static-analysis</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageIcon>assets/configcontraband-icon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/georgepwall1991/ConfigContraband</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/georgepwall1991/ConfigContraband</PackageProjectUrl>
    <PackageReleaseNotes>Add CFG007, a warning for unknown appsettings keys that will throw when a supported binding call explicitly leaves BinderOptions.ErrorOnUnknownConfiguration enabled; reuse CFG006's bindable-property model for strict BindConfiguration, Bind(GetSection(...)), and direct Configure(GetSection(...)) shapes while preserving conservative guards for non-final strict options, constructor/helper/local-helper/delegate-Invoke/non-local-alias escapes, open or polymorphic value shapes, empty collection-expression dictionaries, keys accepted by the strict runtime binder, constructor-assigned dictionary comparers, generic equality-comparer aliases, creatable reference collection and dictionary item members, nested dictionary paths with per-level case-insensitive comparers, and CFG006 fallback visibility when CFG007 is disabled through compilation diagnostic suppression.</PackageReleaseNotes>
    <DevelopmentDependency>true</DevelopmentDependency>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.0.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="5.0.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="4.14.0" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>ConfigContraband.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <None Include="buildTransitive\ConfigContraband.props" Pack="true" PackagePath="buildTransitive\ConfigContraband.props" />
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\assets\configcontraband-icon.png" Pack="true" PackagePath="assets\" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="AnalyzerReleases.Shipped.md" />
    <AdditionalFiles Include="AnalyzerReleases.Unshipped.md" />
  </ItemGroup>

</Project>
